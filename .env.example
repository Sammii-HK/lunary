# ============================================================================
# Lunary — .env.example
#
# Copy this file to .env.local and fill in real values.
#   cp .env.example .env.local
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser. Everything
# else is server-only (do NOT prefix secrets with NEXT_PUBLIC_).
# ============================================================================

# ----------------------------------------------------------------------------
# Application Configuration
# ----------------------------------------------------------------------------
# Public base URL of the app (used in OG/share links, email templates, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Optional canonical site URL (sitemaps, robots, schema.org)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Server-side base URL fallback used by some utilities
APP_BASE_URL=http://localhost:3000
APP_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Database (Neon Postgres)
# ----------------------------------------------------------------------------
# Connection string for Neon Postgres. Used by @vercel/postgres and Prisma.
POSTGRES_URL=postgres://user:password@host/db?sslmode=require

# ----------------------------------------------------------------------------
# Authentication (better-auth)
# ----------------------------------------------------------------------------
# Long random string used to sign better-auth sessions/tokens
BETTER_AUTH_SECRET=your-better-auth-secret-here
# Optional: legacy NextAuth URL fallback used by a few utilities
NEXTAUTH_URL=http://localhost:3000
# Symmetric key used for at-rest encryption of stored credentials/tokens
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# ----------------------------------------------------------------------------
# Stripe (Payments)
# ----------------------------------------------------------------------------
# Get these from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Stripe Price IDs — create products in Dashboard > Products, then copy IDs
NEXT_PUBLIC_STRIPE_MONTHLY_PRICE_ID=price_your_monthly_price_id_here
NEXT_PUBLIC_STRIPE_YEARLY_PRICE_ID=price_your_yearly_price_id_here

# Stripe webhook (subscriptions). From Workbench > Webhooks > Reveal secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Separate webhook secret for the shop / one-off purchases endpoint
STRIPE_WEBHOOK_SECRET_SHOP=whsec_your_shop_webhook_secret_here
# Optional referral coupon ID applied at checkout
STRIPE_REFERRAL_COUPON_ID=

# ----------------------------------------------------------------------------
# RevenueCat (Mobile in-app purchases)
# ----------------------------------------------------------------------------
# Public iOS SDK key (safe to expose)
NEXT_PUBLIC_REVENUECAT_IOS_KEY=appl_your_revenuecat_ios_key_here
# Webhook signing secret for /api/revenuecat/webhook
REVENUECAT_WEBHOOK_SECRET=your-revenuecat-webhook-secret-here

# ----------------------------------------------------------------------------
# Email — Resend + Brevo
# ----------------------------------------------------------------------------
# Resend (transactional email + audiences). https://resend.com
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_AUDIENCE_ID=your-resend-audience-id-here
# Default From / Reply-To for outbound mail
EMAIL_FROM=hello@lunary.app
EMAIL_REPLY_TO=hello@lunary.app

# Brevo (newsletter list management). https://brevo.com
BREVO_API_KEY=your-brevo-api-key-here
BREVO_NEWSLETTER_LIST_ID=1

# ----------------------------------------------------------------------------
# Web Push (VAPID) + Firebase (FCM)
# ----------------------------------------------------------------------------
# Web Push VAPID keys — generate with `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-here

# Firebase Admin (mobile push via FCM). Service account credentials.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
# Note: paste the full PEM, escaped newlines as \n, wrapped in quotes
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# ----------------------------------------------------------------------------
# Analytics — PostHog
# ----------------------------------------------------------------------------
# Public client keys (browser). https://posthog.com
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_api_key_here
# Match the server default (EU region)
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# Server-side personal API key for querying PostHog (insights, cohorts)
POSTHOG_PERSONAL_API_KEY=phx_your_personal_api_key_here
POSTHOG_PROJECT_ID=your-posthog-project-id

# ----------------------------------------------------------------------------
# Storage — Vercel Blob
# ----------------------------------------------------------------------------
# Canonical Vercel Blob token name. Generate in Vercel dashboard > Storage.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your_token_here
# Legacy aliases still referenced in code — set to the same value as above
BLOB_TOKEN=
VERCEL_BLOB_TOKEN=

# ----------------------------------------------------------------------------
# Cron / Internal API auth
# ----------------------------------------------------------------------------
# Bearer token required by /api/cron/* endpoints (Vercel Cron header)
CRON_SECRET=your-long-random-cron-secret-here
# Lunary-specific cron secret (separate consumer)
LUNARY_CRON_SECRET=your-long-random-lunary-cron-secret-here
# Internal service-to-service auth
INTERNAL_API_KEY=your-internal-api-key-here
# Admin-only API key used by lunary-mcp and admin tooling
ADMIN_API_KEY=your-admin-api-key-here
# Analytics endpoint shared secret
ANALYTICS_API_SECRET=your-analytics-api-secret-here
# Shared secret between Lunary and the GPT plugin
LUNARY_GPT_SECRET=your-gpt-shared-secret-here

# ----------------------------------------------------------------------------
# Bot protection — Cloudflare Turnstile
# ----------------------------------------------------------------------------
# https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key-here
TURNSTILE_SECRET_KEY=your-turnstile-secret-key-here

# ----------------------------------------------------------------------------
# Discord (notifications + slash command verification)
# ----------------------------------------------------------------------------
# Public key from Discord Developer Portal > Application > General Information
DISCORD_PUBLIC_KEY=your-discord-public-key-here
# Default webhook URL (fallback for all categories)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# Per-category webhook URLs (optional — fall back to DISCORD_WEBHOOK_URL)
DISCORD_WEBHOOK_ANALYTICS=
DISCORD_WEBHOOK_URGENT=
DISCORD_WEBHOOK_TODO=
DISCORD_WEBHOOK_GENERAL=
DISCORD_WEBHOOK_USER_INTERACTIONS=
# GPT/AI logging webhook + sample rate (0.0–1.0)
DISCORD_GPT_LOG_WEBHOOK=
DISCORD_GPT_LOG_SAMPLE_RATE=0.1
# Quiet hours (24h, local) — mute non-urgent webhooks during this window
DISCORD_QUIET_HOURS_START=22
DISCORD_QUIET_HOURS_END=8

# ----------------------------------------------------------------------------
# Social publishing — Spellcast
# ----------------------------------------------------------------------------
# Internal social-posting service (Spellcast)
SPELLCAST_API_URL=https://spellcast.example.com
SPELLCAST_API_KEY=your-spellcast-api-key-here
SPELLCAST_LUNARY_ACCOUNT_SET_ID=your-spellcast-account-set-id-here
# Optional: comma-separated list of platforms to default-publish to
SPELLCAST_PLATFORMS=instagram,tiktok,x

# ----------------------------------------------------------------------------
# Social publishing — Postiz
# ----------------------------------------------------------------------------
# Postiz REST API base URL (without trailing /public/v1)
POSTIZ_URL=https://postiz.example.com
POSTIZ_API_KEY=your-postiz-api-key-here
ENABLE_POSTIZ=false
# Per-platform integration IDs (from Postiz dashboard > Integrations)
POSTIZ_X_INTEGRATION_ID=
POSTIZ_INSTAGRAM_INTEGRATION_ID=
POSTIZ_TIKTOK_INTEGRATION_ID=
POSTIZ_BLUESKY_INTEGRATION_ID=
POSTIZ_THREADS_INTEGRATION_ID=
POSTIZ_PINTEREST_INTEGRATION_ID=
POSTIZ_REDDIT_INTEGRATION_ID=
POSTIZ_LINKEDIN_INTEGRATION_ID=
POSTIZ_FACEBOOK_INTEGRATION_ID=

# ----------------------------------------------------------------------------
# Social publishing — Ayrshare + Succulent
# ----------------------------------------------------------------------------
# Ayrshare (alternate cross-poster, primarily for YouTube Shorts)
AYRSHARE_API_KEY=your-ayrshare-api-key-here
AYRSHARE_PROFILE_KEY=your-ayrshare-profile-key-here
USE_AYRSHARE_FOR_YOUTUBE=false
# Succulent (legacy Instagram/TikTok poster)
SUCCULENT_SECRET_KEY=your-succulent-secret-key-here
SUCCULENT_ACCOUNT_GROUP_ID=
NEXT_PUBLIC_SUCCULENT_ACCOUNT_GROUP_ID=

# ----------------------------------------------------------------------------
# Substack
# ----------------------------------------------------------------------------
SUBSTACK_PUBLICATION_URL=https://yourpub.substack.com
SUBSTACK_EMAIL=
SUBSTACK_PASSWORD=

# ----------------------------------------------------------------------------
# AI / LLM providers
# ----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
DEEPINFRA_API_KEY=your-deepinfra-api-key-here
ELEVENLABS_KEY=your-elevenlabs-api-key-here
# Optional: self-hosted Ollama for transit/scoring
OLLAMA_URL=http://localhost:11434
OLLAMA_WRITER_MODEL=llama3.1
OLLAMA_SCORER_MODEL=llama3.1
TRANSIT_USE_OLLAMA=false
# Optional: Open-WebUI bridge
OPEN_WEBUI_URL=
OPEN_WEBUI_API_KEY=
# Verbose AI context logging (development only)
AI_CONTEXT_DEBUG=false

# ----------------------------------------------------------------------------
# Google APIs (Search Console, Sheets, Service Account)
# ----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
# Full service account JSON, single-line escaped
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
GOOGLE_SEARCH_CONSOLE_SITE_URL=https://lunary.app/
GOOGLE_SHEETS_ID=

# ----------------------------------------------------------------------------
# Cloudflare KV (edge-cached data)
# ----------------------------------------------------------------------------
CLOUDFLARE_KV_ACCOUNT_ID=your-cloudflare-account-id-here
CLOUDFLARE_KV_API_TOKEN=your-cloudflare-api-token-here
CLOUDFLARE_KV_NAMESPACE_ID=your-kv-namespace-id-here

# ----------------------------------------------------------------------------
# Geocoding — LocationIQ
# ----------------------------------------------------------------------------
LOCATIONIQ_API_KEY=your-locationiq-api-key-here
LOCATIONIQ_BASE_URL=https://us1.locationiq.com/v1

# ----------------------------------------------------------------------------
# Currency / FX rates
# ----------------------------------------------------------------------------
FX_RATE_API_KEY=your-fx-api-key-here
FX_RATE_API_URL=https://api.exchangerate.host
FX_DRIFT_AUTO_APPLY=false
FX_DRIFT_CADENCE_MONTHS=3
FX_DRIFT_UPDATE_THRESHOLD=0.05

# ----------------------------------------------------------------------------
# GitHub (issue/PR automation)
# ----------------------------------------------------------------------------
GITHUB_TOKEN=ghp_your-github-token-here
GITHUB_OWNER=sammii
GITHUB_REPO=lunary
GITHUB_DEFAULT_BRANCH=main

# ----------------------------------------------------------------------------
# Push notifications — Pushover (admin alerts)
# ----------------------------------------------------------------------------
PUSHOVER_API_TOKEN=your-pushover-app-token-here
PUSHOVER_USER_KEY=your-pushover-user-key-here

# ----------------------------------------------------------------------------
# Podify (podcast generation)
# ----------------------------------------------------------------------------
PODIFY_API_URL=https://api.podify.example.com
PODIFY_API_KEY=your-podify-api-key-here

# ----------------------------------------------------------------------------
# Jazz (collaborative state worker)
# ----------------------------------------------------------------------------
JAZZ_WORKER_ACCOUNT=
JAZZ_WORKER_SECRET=

# ----------------------------------------------------------------------------
# Content rendering services (video/Remotion + image generation)
# ----------------------------------------------------------------------------
CONTENT_CREATOR_URL=
CONTENT_RENDER_URL=
LUNARY_IMAGE_BASE_URL=
LUNARY_SHARE_BASE_URL=

# ----------------------------------------------------------------------------
# YouTube (playlists used by social/cron flows)
# ----------------------------------------------------------------------------
YOUTUBE_SHORTS_PLAYLIST_ID=
YOUTUBE_WEEKLY_SERIES_PLAYLIST_ID=

# ----------------------------------------------------------------------------
# Lunary MCP (admin tooling — used by lunary-mcp/)
# ----------------------------------------------------------------------------
# Base URL the MCP server hits (usually NEXT_PUBLIC_APP_URL in prod)
LUNARY_API_URL=http://localhost:3000
# Admin key the MCP server passes to admin endpoints
LUNARY_ADMIN_KEY=your-lunary-admin-key-here

# ----------------------------------------------------------------------------
# Admin / debug overrides
# ----------------------------------------------------------------------------
# Comma-separated list of admin emails that bypass paywall/checks
ADMIN_EMAILS=you@example.com
ADMIN_EMAIL=you@example.com
NEXT_PUBLIC_ADMIN_EMAILS=you@example.com
NEXT_PUBLIC_ADMIN_EMAIL=you@example.com
# Public host(s) the admin dashboard is mounted on
ADMIN_APP_HOST=admin.lunary.app
ADMIN_DASHBOARD_HOST=admin.lunary.app
NEXT_PUBLIC_ADMIN_APP_HOST=admin.lunary.app
NEXT_PUBLIC_ADMIN_APP_URL=https://admin.lunary.app
# Token used by admin debug routes (dev only)
NEXT_PUBLIC_ADMIN_DEBUG_TOKEN=
NEXT_PUBLIC_ADMIN_TOKEN=
# Auth bypass / debug switches — DO NOT enable in production
SKIP_AUTH=false
BYPASS_AUTH=false
DEBUG_AUTH=false
DEBUG_LIFE_THEMES=false
# Override active feature flags (comma-separated flag=value pairs)
FEATURE_FLAGS_OVERRIDE=
# Migration rollout controls
ENABLE_MIGRATION_LOGGING=false
ENABLE_POSTGRES_PROFILE=false
MIGRATION_ROLLOUT_PERCENTAGE=0
# Skip static page generation during build (CI optimisation)
SKIP_STATIC_GENERATION=false

# ----------------------------------------------------------------------------
# Test accounts (Playwright + unit tests)
# ----------------------------------------------------------------------------
PERSONA_EMAIL=your_test_account@example.com
PERSONA_PASSWORD=your_test_password
PERSONA_BIRTHDAY=1990-01-15
TEST_USER_EMAIL=test@example.com
TEST_USER_ID=
TEST_PLAN=free
PLAYWRIGHT_TEST_BASE_URL=http://localhost:3000

# ============================================================================
# SETUP INSTRUCTIONS
# ----------------------------------------------------------------------------
# 1. Copy this file:                cp .env.example .env.local
# 2. Fill in real values for any integration you plan to use locally.
#    Most integrations are optional — leave unused vars blank.
# 3. Restart dev server:            yarn dev (or pnpm dev)
# 4. Test Stripe at:                http://localhost:3000/test-stripe
# 5. Stripe webhook endpoint:       http://localhost:3000/api/stripe/webhooks
# ============================================================================
