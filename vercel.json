{
  "buildCommand": "pnpm run build:deploy",
  "framework": "nextjs",
  "ignoreCommand": "if [[ \"$VERCEL_GIT_COMMIT_AUTHOR_LOGIN\" == \"dependabot[bot]\" ]]; then exit 0; else exit 1; fi",
  "crons": [
    {
      "path": "/api/cron/generate-daily-tarot",
      "schedule": "5 0 * * *"
    },
    {
      "path": "/api/cron/process-deletions",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/update-global-cosmic-data",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/daily-morning-notification",
      "schedule": "30 7 * * *"
    },
    {
      "path": "/api/cron/weekly-content",
      "schedule": "0 7 * * 0"
    },
    {
      "path": "/api/cron/daily-posts",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/daily-stories",
      "schedule": "30 8 * * *"
    },
    {
      "path": "/api/cron/daily-threads",
      "schedule": "15 9 * * *"
    },
    {
      "path": "/api/cron/daily-cosmic-pulse",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/moon-circles",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/cron/fx-drift",
      "schedule": "0 9 1 * *"
    },
    {
      "path": "/api/cron/yearly-tarot-analysis",
      "schedule": "15 0 1 1 *"
    },
    {
      "path": "/api/cron/compute-transit-dates",
      "schedule": "30 0 1 1 *"
    },
    {
      "path": "/api/cron/activate-retrograde-spaces",
      "schedule": "15 6 * * *"
    },
    {
      "path": "/api/cron/weekly-subscription-sync",
      "schedule": "0 2 * * 0"
    },
    {
      "path": "/api/cron/generate-weekly-challenge",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/cron/sammii-og",
      "schedule": "30 9 * * *"
    },
    {
      "path": "/api/cron/bip-weekly",
      "schedule": "0 2 * * 1"
    },
    {
      "path": "/api/admin/stripe-sync",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/compute-metrics",
      "schedule": "0 4 * * *"
    }
  ]
}
