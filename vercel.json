{
  "buildCommand": "if [ \"$VERCEL_ENV\" = \"production\" ]; then pnpm run build:deploy; else pnpm run build; fi",
  "framework": "nextjs",
  "ignoreCommand": "if [[ \"$VERCEL_GIT_COMMIT_AUTHOR_LOGIN\" == \"dependabot[bot]\" ]]; then exit 0; else exit 1; fi",
  "functions": {
    "src/app/api/og/**/*.tsx": {
      "memory": 512
    },
    "src/app/api/ether/**/*.ts": {
      "memory": 256
    },
    "src/app/api/telemetry/**/*.ts": {
      "memory": 256
    },
    "src/app/api/cosmic/**/*.ts": {
