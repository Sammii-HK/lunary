# Add common paths where pnpm might be installed
export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

# Block direct pushes to main — must use a PR
while read local_ref local_oid remote_ref remote_oid; do
  if echo "$remote_ref" | grep -qE "refs/heads/main$"; then
    echo "❌ Direct push to main is blocked. Create a branch and open a PR instead."
    echo "   To fix: git push origin $(git symbolic-ref --short HEAD) && gh pr create"
    exit 1
  fi
done

# Require a green build before pushing.
# The build takes ~8min which kills SSH, so we check a stamp file instead.
# Run: pnpm build (or npx next build) before pushing. The pre-commit hook
# or a manual run creates .build-ok with the HEAD commit hash.
BUILD_STAMP=".build-ok"
HEAD_SHA=$(git rev-parse HEAD)

if [ ! -f "$BUILD_STAMP" ] || [ "$(cat "$BUILD_STAMP")" != "$HEAD_SHA" ]; then
  echo "❌ No green build for current commit."
  echo "   Run 'npx next build && git rev-parse HEAD > .build-ok' first."
  echo "   Expected: $HEAD_SHA"
  if [ -f "$BUILD_STAMP" ]; then
    echo "   Found:    $(cat "$BUILD_STAMP")"
  else
    echo "   Found:    (no .build-ok file)"
  fi
  exit 1
fi

echo "✅ Build stamp matches HEAD. Push allowed."

# ─── Security scan: catch common vulnerabilities before push ─────────
# Only scans files changed since origin, fast enough for pre-push.
SECURITY_ISSUES=0

# Get changed .ts/.tsx files (compared to merge-base with main)
MERGE_BASE=$(git merge-base HEAD origin/main 2>/dev/null || echo "HEAD~1")
CHANGED_FILES=$(git diff --name-only "$MERGE_BASE"..HEAD -- '*.ts' '*.tsx' 2>/dev/null | grep -v '__tests__/' | grep -v '.test.' || true)

if [ -n "$CHANGED_FILES" ]; then
  # 1. Implicit null in SQL templates: ${null} → use typed SQL_NULL variable
  NULL_HITS=$(echo "$CHANGED_FILES" | xargs grep -n '\${null}' 2>/dev/null || true)
  if [ -n "$NULL_HITS" ]; then
    echo "⚠️  Implicit \${null} in SQL template (CodeQL: implicit-operand-conversion)"
    echo "   Use a typed variable instead: const SQL_NULL: string | null = null;"
    echo "$NULL_HITS" | head -5
    SECURITY_ISSUES=$((SECURITY_ISSUES + 1))
  fi

  # 2. SSRF: fetch() with template literals using variables (not constants)
  #    Catches: fetch(\`${baseUrl}/...\`) where baseUrl could be user-controlled
  SSRF_HITS=$(echo "$CHANGED_FILES" | xargs grep -nE 'fetch\(`\$\{[a-z]' 2>/dev/null | grep -v 'SQL_NULL\|process\.env\|getBaseUrl\(\)' || true)
  if [ -n "$SSRF_HITS" ]; then
    echo "⚠️  Potential SSRF: fetch() URL uses variable interpolation (CodeQL: js/request-forgery)"
    echo "   Validate URLs against an allow-list before fetching."
    echo "$SSRF_HITS" | head -5
    SECURITY_ISSUES=$((SECURITY_ISSUES + 1))
  fi

  # 3. ReDoS: regex with HTML tag stripping on user input
  REDOS_HITS=$(echo "$CHANGED_FILES" | xargs grep -nE '\.replace\(/<\[' 2>/dev/null || true)
  if [ -n "$REDOS_HITS" ]; then
    echo "⚠️  Potential ReDoS: regex HTML tag stripping (CodeQL: js/polynomial-redos)"
    echo "   Use stripHtmlTags() from @/lib/utils instead."
    echo "$REDOS_HITS" | head -5
    SECURITY_ISSUES=$((SECURITY_ISSUES + 1))
  fi

  # 4. Log injection: console.log with user-controlled template literals in API routes
  LOG_INJ_HITS=$(echo "$CHANGED_FILES" | grep -E 'route\.ts' | xargs grep -nE 'console\.(log|error)\(.*\$\{(req|request)\.(body|query|params)' 2>/dev/null || true)
  if [ -n "$LOG_INJ_HITS" ]; then
    echo "⚠️  Potential log injection: logging raw request data (CodeQL: js/log-injection)"
    echo "   Sanitise or use allow-listed values in logs."
    echo "$LOG_INJ_HITS" | head -5
    SECURITY_ISSUES=$((SECURITY_ISSUES + 1))
  fi
fi

if [ "$SECURITY_ISSUES" -gt 0 ]; then
  echo ""
  echo "❌ Found $SECURITY_ISSUES security issue(s). Fix them before pushing."
  echo "   See CLAUDE.md security sections for patterns."
  exit 1
fi

echo "✅ Security scan passed."

# Check if cloudflare-worker has changes and deploy if needed
git diff --stat HEAD@{1}..HEAD 2>/dev/null | grep -q cloudflare-worker && ./scripts/check-and-deploy-worker.sh "$@" || true
